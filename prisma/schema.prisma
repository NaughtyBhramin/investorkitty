generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SEEKER
  INVESTOR
  ADMIN
}

enum StartupStage {
  IDEA
  POC
  MVP
  GROWTH
}

enum MatchStatus {
  PENDING
  CONNECTED
  PASSED
}

enum InvestorTagStatus {
  REVIEWING
  DUE_DILIGENCE
  COMMITTED
  PASSED
}

enum NotificationType {
  MATCH
  MESSAGE
  MEETING
  SYSTEM
}

model User {
  id             String        @id @default(uuid())
  role           UserRole      @default(SEEKER)
  email          String        @unique
  passwordHash   String?
  name           String?
  image          String?
  emailVerified  DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  seekerProfile  SeekerProfile?
  investorProfile InvestorProfile?
  sessions       Session[]
  accounts       Account[]
  meetingRequestsSent     MeetingRequest[] @relation("MeetingRequester")
  meetingRequestsReceived MeetingRequest[] @relation("MeetingInvitee")
  notifications  Notification[]
  messages       Message[]      @relation("senderMessages")
  received       Message[]      @relation("receiverMessages")
  matchesAsSeeker Match[]       @relation("seekerMatches")
  matchesAsInvestor Match[]     @relation("investorMatches")
}

model SeekerProfile {
  id             String       @id @default(uuid())
  user           User         @relation(fields: [userId], references: [id])
  userId         String       @unique
  companyName    String
  headline       String
  pitchDeckUrl   String?
  stage          StartupStage
  fundingGoal    Int
  equityOffered  Int
  industries     String[]
  traction       Json
  teamMembers    Json
  location       String?
  website        String?
  linkedIn       String?
  angelList      String?
  kittyScore     Int          @default(1)
  profileViews   Int          @default(0)
  investorInterest Int        @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model InvestorProfile {
  id              String       @id @default(uuid())
  user            User         @relation(fields: [userId], references: [id])
  userId          String       @unique
  firmName        String
  investmentRange String
  preferredIndustries String[]
  ticketSize      String
  portfolio       Json
  website         String?
  location        String?
  linkedin        String?
  angelList       String?
  profileViews    Int          @default(0)
  matchesReviewed Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Match {
  id             String        @id @default(uuid())
  seeker         User          @relation("seekerMatches", fields: [seekerId], references: [id])
  seekerId       String
  investor       User          @relation("investorMatches", fields: [investorId], references: [id])
  investorId     String
  seekerLiked    Boolean       @default(false)
  investorLiked  Boolean       @default(false)
  status         MatchStatus   @default(PENDING)
  tagStatus      InvestorTagStatus @default(REVIEWING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Message {
  id             String        @id @default(uuid())
  threadId       String
  sender         User          @relation("senderMessages", fields: [senderId], references: [id])
  senderId       String
  receiver       User          @relation("receiverMessages", fields: [receiverId], references: [id])
  receiverId     String
  content        String
  attachmentUrl  String?
  createdAt      DateTime      @default(now())
  read           Boolean       @default(false)
}

model Notification {
  id             String           @id @default(uuid())
  user           User             @relation(fields: [userId], references: [id])
  userId         String
  type           NotificationType
  title          String
  message        String
  url            String?
  read           Boolean          @default(false)
  createdAt      DateTime         @default(now())
}

model Resource {
  id             String    @id @default(uuid())
  title          String
  description    String
  url            String
  category       String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model MeetingRequest {
  id             String    @id @default(uuid())
  requester      User      @relation("MeetingRequester", fields: [requesterId], references: [id])
  requesterId    String
  invitee        User      @relation("MeetingInvitee", fields: [inviteeId], references: [id])
  inviteeId      String
  scheduledFor   DateTime
  notes          String?
  status         String    @default("PENDING")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Account {
  id                 String   @id @default(uuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  oauth_token_secret String?
  oauth_token        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, token])
}
